<mxfile host="Electron">
  <diagram name="项目流程图" id="main">
    <mxGraphModel dx="3201" dy="-880" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    %% ========== 项目启动链路 ==========\n    S([\&quot;开始：DemoApplication.main()\&quot;])\n    S1[SpringApplication.run 启动Spring容器]\n    S2[AppRunner.run 执行启动后置逻辑]\n    %% 微信Bot启动分支\n    W1[WeChatBotService.start 初始化微信机器人]\n    W2[SessionManager.load 读取本地登录凭证]\n    J1{存在历史会话凭证？}\n    J1Y[3秒倒计时自动登录promptAutoLogin]\n    J1N[直接扫码登录startWithQR]\n    J2{倒计时内按下Enter？}\n    J2Y[执行扫码登录executeLogin 获取二维码]\n    J2N[恢复会话登录loginContext]\n    QR_SUCCESS{扫码成功？}\n    QR_Y[SessionManager.save 持久化登录凭证]\n    QR_Y2[启动HeartbeatService 5s轮询消息]\n    QR_N([\&quot;启动失败，流程终止\&quot;])\n    %% CLI启动分支\n    C1[CommandExecutor.start 启动命令行终端]\n    C2[Scanner持续监听控制台输入]\n    END_READY([\&quot;服务全部就绪，等待消息/终端指令\&quot;])\n\n    %% ========== 微信消息处理主链路 ==========\n    M_START([\&quot;心跳轮询触发消息接收\&quot;])\n    M1[ILinkClient.pollAndDispatchMessages SDK拉取消息]\n    M2[OnMessageListener.onMessages 接收消息列表]\n    M3[WeChatBotService.handleMessages 批量分发消息]\n    M4[WeChatBotService.handleMessage 单条消息处理]\n    M5[提取发送用户ID from_user_id]\n    M6{消息Item类型判断}\n    %% 分支1：图片消息处理\n    IMG[handleImageMessage 图片消息分支]\n    IMG1[downloadImageFromMessageItem 下载图片byte数组]\n    IMG2[创建临时文件存储图片]\n    IMG3[ImageService.recognizeImage 调用qwen-vl-max识图]\n    IMG4[删除临时文件]\n    IMG5[获取图片文字描述结果]\n    SEND_TEXT[sendReply 调用client.sendText返回文本]\n    %% 分支2：文字消息处理\n    TEXT[提取用户输入文本]\n    ROUTE[CommandRouter.route 消息路由分发]\n    CMD_MATCH{精确匹配内置命令？}\n    CMD_EXEC[Command.execute 执行对应命令实现]\n    LLM_BRANCH[未匹配则进入LLM function calling流程]\n    LLM1[ChatService.getHistory 获取该用户对话历史]\n    LLM2[LlmService.chat 携带tools调用qwen-plus]\n    LLM_JUDGE{大模型function_call类型}\n    %% LLM分支1：天气查询\n    WEATHER[提取城市、天数参数]\n    W_JUDGE{查询类型分流}\n    W_REAL[WeatherService.getWeather 实时天气now接口]\n    W_FORECAST[WeatherService.getForecastMulti 多天预报daily接口]\n    W_LLM[主观/历史天气，千问直接生成回答]\n    W_FORMAT[格式化气象文本结果]\n    W_SAVE[ChatService.addHistory 保存对话记录]\n    %% LLM分支2：文生图\n    IMG_GEN[提取绘图提示词，返回IMG_GEN:前缀标记]\n    %% LLM分支3：内置指令help/status/version\n    LCMD_EXEC[执行Help/Version/Status命令]\n    %% LLM分支4：普通对话\n    CHAT_NORMAL[千问直接生成文本，保存对话历史]\n    %% 生图统一处理链路\n    GEN_DETECT{sendReply检测到IMG_GEN标记？}\n    GEN1[ImageService.generateImage 调用wan2.6-t2i]\n    GEN2[拉取云端图片URL并下载byte数组]\n    SEND_IMG[client.sendImage 推送图片给用户]\n    %% 通用文本回复出口\n    COMMON_SEND[sendReply 统一回复文本]\n    %% 单条消息结束节点\n    MSG_END([\&quot;本条消息处理完成\&quot;])\n\n    %% ========== CLI命令行独立链路 ==========\n    CLI_LOOP[循环读取控制台输入]\n    CLI_SPLIT[空格分词拆分命令名+参数]\n    CLI_EXIT{输入exit指令？}\n    CLI_QUIT([\&quot;程序退出\&quot;])\n    CLI_FIND[查找对应Command实现]\n    CLI_RUN[Command.execute 执行命令，无LLM调用]\n\n    %% ===================== 连线关系 =====================\n    %% 启动流程连线\n    S --&gt; S1 --&gt; S2\n    S2 --&gt; W1 &amp; C1\n    W1 --&gt; W2 --&gt; J1\n    J1 -- 有凭证 --&gt; J1Y --&gt; J2\n    J1 -- 无凭证 --&gt; J1N --&gt; J2Y --&gt; QR_SUCCESS\n    J2 -- 按下Enter --&gt; J2Y\n    J2 -- 超时 --&gt; J2N --&gt; QR_SUCCESS\n    QR_SUCCESS -- 成功 --&gt; QR_Y --&gt; QR_Y2\n    QR_SUCCESS -- 失败 --&gt; QR_N\n    QR_Y2 &amp; C1 --&gt; END_READY\n\n    %% 微信消息主循环\n    END_READY --&gt; M_START --&gt; M1 --&gt; M2 --&gt; M3 --&gt; M4 --&gt; M5 --&gt; M6\n    M6 -- 图片消息 --&gt; IMG --&gt; IMG1 --&gt; IMG2 --&gt; IMG3 --&gt; IMG4 --&gt; IMG5 --&gt; SEND_TEXT --&gt; MSG_END\n    M6 -- 文字消息 --&gt; TEXT --&gt; ROUTE --&gt; CMD_MATCH\n    CMD_MATCH -- 命中命令 --&gt; CMD_EXEC --&gt; COMMON_SEND --&gt; MSG_END\n    CMD_MATCH -- 未命中 --&gt; LLM_BRANCH --&gt; LLM1 --&gt; LLM2 --&gt; LLM_JUDGE\n\n    %% LLM四类分支\n    LLM_JUDGE -- weather天气 --&gt; WEATHER --&gt; W_JUDGE\n    W_JUDGE -- 实时当日 --&gt; W_REAL --&gt; W_FORMAT --&gt; W_SAVE --&gt; COMMON_SEND\n    W_JUDGE -- 未来多天 --&gt; W_FORECAST --&gt; W_FORMAT --&gt; W_SAVE --&gt; COMMON_SEND\n    W_JUDGE -- 历史/主观感受 --&gt; W_LLM --&gt; W_SAVE --&gt; COMMON_SEND\n    LLM_JUDGE -- generate_image绘图 --&gt; IMG_GEN --&gt; GEN_DETECT\n    LLM_JUDGE -- help/status/version --&gt; LCMD_EXEC --&gt; COMMON_SEND\n    LLM_JUDGE -- 普通文本对话 --&gt; CHAT_NORMAL --&gt; COMMON_SEND\n\n    %% 生图链路\n    GEN_DETECT -- 是IMG_GEN标记 --&gt; GEN1 --&gt; GEN2 --&gt; SEND_IMG --&gt; MSG_END\n    GEN_DETECT -- 普通文本 --&gt; COMMON_SEND --&gt; MSG_END\n\n    %% CLI终端流程\n    END_READY --&gt; CLI_LOOP --&gt; CLI_SPLIT --&gt; CLI_EXIT\n    CLI_EXIT -- 是exit --&gt; CLI_QUIT\n    CLI_EXIT -- 其他指令 --&gt; CLI_FIND --&gt; CLI_RUN --&gt; CLI_LOOP&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="bGEqctSjBSjHGRPcDLjl-119">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="开始：DemoApplication.main()" mermaidId="n:S" mermaidBaseStyle="html=1;rounded=1;whiteSpace=wrap;arcSize=50;strokeWidth=1;fillColor=light-dark(#ECECFF,#1f2020);strokeColor=light-dark(#9370DB,#cccccc);fontColor=light-dark(#333333,#cccccc);fontFamily=Trebuchet MS,Verdana,Arial,sans-serif;fontSize=16;" mermaidBaseValue="开始：DemoApplication.main()" id="bGEqctSjBSjHGRPcDLjl-120">
