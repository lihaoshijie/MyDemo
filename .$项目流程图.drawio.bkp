<mxfile host="Electron">
  <diagram name="第 1 页" id="pww9o-x5scXDaThb7p_c">
    <mxGraphModel dx="2402" dy="1380" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    %% 启动入口\n    A[开始: DemoApplication.main] --&gt; B[SessionManager加载会话持久化]\n    B --&gt; C[SpringApplication.run 启动Spring容器]\n    C --&gt; D[AppRunner.run 项目启动调度器]\n    D --&gt; D1[WeChatBotService.start 微信机器人初始化]\n    D --&gt; D2[CommandExecutor.start 命令行工具]\n\n    %% 登录分支\n    D1 --&gt; E{存在历史会话凭证?}\n    E -- 是 --&gt; F[3秒倒计时等待切换账号]\n    F -- 倒计时结束 --&gt; G[startWithSession 免扫码自动登录]\n    F -- 按下Enter回车 --&gt; H[清空Session缓存]\n    E -- 否 --&gt; H\n    H --&gt; I[startWithQR 扫码登录流程]\n    G &amp; I --&gt; J[登录成功 启动Heartbeat心跳服务]\n    J --&gt; K[ILinkClient 持续轮询接收微信消息]\n\n    %% 消息接收分发\n    K --&gt; L[OnMessageListener 消息回调入口]\n    L --&gt; M[WeChatBotService.handleMessage 统一消息处理]\n    M --&gt; N{消息类型判断}\n\n    %% 语音消息分支\n    N -- 语音消息 --&gt; N1[SDK自动语音转文字]\n    N1 --&gt; O[CommandRouter.route 消息路由分发]\n    %% 图片消息分支\n    N -- 图片消息 --&gt; P[handleImageMessage 图片处理分支]\n    P --&gt; P1[downloadImageFromStream 下载图片二进制]\n    P1 --&gt; P2[ImageService.recognizeImage qwen-vl-max识图]\n    P2 --&gt; P3[存入图片缓存池(5张上限/5分钟TTL)]\n    P3 --&gt; O\n    %% 纯文字消息分支\n    N -- 纯文字 --&gt; O\n\n    %% 路由命令判断\n    O --&gt; Q{是否匹配内置固定命令?}\n    Q -- 是 --&gt; Q1[清空用户图片缓存]\n    Q1 --&gt; Q2[CommandExecutor执行对应内置命令]\n    Q2 --&gt; Q21[WeatherCommand天气/Help帮助/Version版本]\n    Q21 --&gt; Z[sendReply统一回复输出]\n    Q -- 否 --&gt; R[进入LLM Function Calling流程]\n\n    %% LLM大模型处理\n    R --&gt; R1[ChatService拼接对话历史]\n    R1 --&gt; R2[LlmService调用qwen-plus 携带工具列表]\n    R2 --&gt; S{模型返回Function调用指令?}\n\n    %% 分支1：天气工具调用\n    S -- 天气weather --&gt; T[解析城市、天数参数]\n    T --&gt; T1{实时/多日预报区分}\n    T1 -- 实时天气 --&gt; T2[WeatherService.getNow 心知实时接口]\n    T1 -- 未来多天 --&gt; T3[WeatherService.getForecastMulti 多日预报接口]\n    T2 &amp; T3 --&gt; T4[格式化气象文本结果]\n    T4 --&gt; Z\n\n    %% 分支2：生图工具调用\n    S -- 生图generate_image --&gt; U{用户存在有效图片缓存?}\n    U -- 有原图 --&gt; U1[ImageService.transformImage wan2.6-image图生图]\n    U -- 无原图 --&gt; U2[ImageService.generateImage wan2.6-t2i文生图]\n    U1 &amp; U2 --&gt; U3[生成图片二进制文件]\n    U3 --&gt; Z\n\n    %% 分支3：版本/闲聊无工具\n    S -- version版本 --&gt; V[读取项目版本文案]\n    S -- 纯文本闲聊 --&gt; W[模型直接返回对话文本]\n    V &amp; W --&gt; Z\n\n    %% 统一回复处理\n    Z --&gt; X{用户开启语音模式?}\n    X -- 是 --&gt; X1[VoiceService.textToSpeech cosyvoice-v3-flash合成语音]\n    X1 --&gt; X2[ILinkClient.sendVoice推送语音消息]\n    X -- 否 --&gt; X3[ILinkClient.sendText发送文字]\n    Z -- 图片输出 --&gt; X4[ILinkClient.sendImage推送图片]\n    X2 &amp; X3 &amp; X4 --&gt; Y[本轮消息处理完成，等待下一条消息]&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="cFJaBc2txUQ8dU8Fzqrk-1">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=10;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
        </UserObject>
